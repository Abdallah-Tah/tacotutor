# TacoTutor env (copy to .env and fill in keys you need)

# LLM — only set keys for providers you use
# Ollama needs no key (local)
# GOOGLE_API_KEY=    # Gemini also works with GOOGLE_API_KEY
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MINIMAX_API_KEY=
# GLM_API_KEY=
# OPENROUTER_API_KEY=
# HF_API_KEY=
# HF_TOKEN=

# TacoTutor also reads matching keys from ~/.config/openclaw/secrets.env
# HUGGINGFACE_TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest

# STT
# Deepgram needs no key if using local whisper
# DEEPGRAM_API_KEY=
# HF_API_KEY=
